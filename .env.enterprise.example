# --- AgentFlow Enterprise (v2.0) Environment Configuration ---

# 1. Database Configuration (PostgreSQL 16)
DB_NAME=agentflow_v2
DB_USER=admin
DB_PASSWORD=secret_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# 2. Cache & Messaging (Redis 7)
REDIS_URL=redis://redis:6379/0

# 3. API Gateway Settings (FastAPI)
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
DEBUG=false
SECRET_KEY=generate_a_secure_random_string_here
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# 4. Orchestrator Settings
MAX_CONCURRENT_TASKS=10
WORKER_RETRY_LIMIT=3
ORCHESTRATOR_POLLING_INTERVAL=5

# 5. Frontend Dashboard (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/v2
PORT=3000

# 6. External Integrations (Optional)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
