{
  "openapi": "3.1.0",
  "info": {
    "title": "MarkOS-AgentFlow Enterprise API",
    "description": "Enterprise-grade multi-agent orchestration platform.",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health Check",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthStatus" }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects": {
      "get": {
        "tags": ["Projects"],
        "summary": "List Projects",
        "responses": {
          "200": { "description": "List of projects" }
        }
      }
    },
    "/api/v1/tasks": {
      "post": {
        "tags": ["Tasks"],
        "summary": "Create Task",
        "responses": {
          "201": { "description": "Task created" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthStatus": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "app": { "type": "string" },
          "database": { "type": "string" },
          "redis": { "type": "string" }
        }
      }
    }
  }
}
