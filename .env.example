# MarkOS-AgentFlow Environment Variables Template

# 1. Database (PostgreSQL)
# -------------------------
# The name of the database to be created
DB_NAME=agentflow
# Master database user
DB_USER=admin
# Master database password (Change this!)
DB_PASSWORD=agentflow_secret_123
# External port mapping
DB_PORT=5432

# 2. Redis
# ---------
# Redis connection URL for task queuing and caching
REDIS_URL=redis://redis:6379/0

# 3. Backend (FastAPI)
# ---------------------
# Project title shown in API docs
PROJECT_NAME=MarkOS-AgentFlow
# Base API version prefix
API_V1_STR=/api/v1
# Secret key for JWT token generation (Generate a secure one!)
SECRET_KEY=yoursecretkeyhere
# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=11520
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
# App execution environment (dev/prod)
APP_ENV=dev
# Enable/disable debug mode (true/false)
APP_DEBUG=true

# 4. Frontend (Next.js)
# ----------------------
# Public API URL for client-side fetching
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
